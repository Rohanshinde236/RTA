# ============================================================
# RTA Per-Skill SLA Monitoring System — config.env template
# Copy this file to config.env and fill in your values:
#   Copy-Item config.env.example config.env   (Windows PowerShell)
#   cp config.env.example config.env           (mac/linux)
# config.env is gitignored — never commit real credentials.
# ============================================================

# --- Excel KPI path for Agent 3 (optional — Excel lever lookups) ---
KPI_EXCEL_PATH=C:\path\to\Voice_Queue_Intraday.xlsx

# --- Dashboard Scraper Login (creds for the RTA dashboard pages) ---
SCRAPER_USER=your_username@AA
SCRAPER_PASS=your_password

# --- Email (SMTP) — Agent 1 band-drop + Agent 3 lever emails ---
# Gmail: use an App Password (https://support.google.com/accounts/answer/185833)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_MANAGERS=manager1@company.com,manager2@company.com

# ── NVIDIA NIM API — PRIMARY for lever analysis ─────────────
# Add up to 9 keys (NVIDIA_API_KEY_1 .. _9) — they rotate round-robin.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_API_KEY_1=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NVIDIA_API_KEY_2=
# NVIDIA_API_KEY_3=

# ── Groq API keys — PRIMARY for chat, fallback for levers ───
# GROQ_MODEL      = SQL generation (short prompts, fast 8k model)
# GROQ_MODEL_CHAT = chat answers (large context — needs 32k window)
# Add up to 9 keys (GROQ_API_KEY_1 .. _9).
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_CHAT=llama-3.3-70b-versatile
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_API_KEY_2=

# ── Gemini keys — last-resort fallback (add 1..9) ───────────
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_KEY_1=AIza-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY_2=

# ─── Regions (fallback only) ────────────────────────────────
# The live region list is read from config.json. These env entries are used
# only if config.json is missing. Each region needs its own Teams webhook
# (Power Automate "When a HTTP request is received" trigger URL).
REGION_1_NAME=RTA
REGION_1_DISPLAY=Client ProSupport IND
REGION_1_DASHBOARD=ui/RTA.html
REGION_1_TEAMS_WEBHOOK=

REGION_2_NAME=CN
REGION_2_DISPLAY=Client ProSupport CHN
REGION_2_DASHBOARD=ui/RTA_CN.html
REGION_2_TEAMS_WEBHOOK=

REGION_3_NAME=AU
REGION_3_DISPLAY=Client ProSupport AUS
REGION_3_DASHBOARD=ui/RTA_AU.html
REGION_3_TEAMS_WEBHOOK=

REGION_4_NAME=EMEA
REGION_4_DISPLAY=Client ProSupport EMEA
REGION_4_DASHBOARD=ui/RTA_EMEA.html
REGION_4_TEAMS_WEBHOOK=
